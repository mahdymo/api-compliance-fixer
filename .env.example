# ── App ────────────────────────────────────────────────────────────────────────
BASE_URL=https://your-app.up.railway.app

# ── Google Forms integration ───────────────────────────────────────────────────
# HOW TO GET THESE VALUES — takes about 5 minutes:
#
# 1. Go to https://forms.google.com and create a new form.
#
# 2. Add these fields (Short answer unless noted):
#      Name | Work Email | Company | Role | How heard (Dropdown) |
#      Use case | Collection name | Frameworks | Total changes | Format | Timestamp
#
# 3. Click the three-dot menu (⋮) → "Get pre-filled link"
#    Fill in dummy values for every field → click "Get link" → copy the URL.
#
# 4. The URL looks like:
#    https://docs.google.com/forms/d/e/1FAIpQLSe.../viewform?
#      entry.123456789=Name&entry.987654321=Email&...
#
#    Your GFORM_URL is the same base path but ending in /formResponse:
#    https://docs.google.com/forms/d/e/1FAIpQLSe.../formResponse
#
#    Each GFORM_* variable is the entry.XXXXXXXXXX key for that field.
#
# 5. Link the form to a spreadsheet:
#    Responses tab → green Sheets icon → Create new spreadsheet.
#    Submissions appear there in real time.

GFORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/formResponse

GFORM_NAME=entry.000000001
GFORM_EMAIL=entry.000000002
GFORM_COMPANY=entry.000000003
GFORM_ROLE=entry.000000004
GFORM_HOW_HEARD=entry.000000005
GFORM_USE_CASE=entry.000000006
GFORM_COLLECTION=entry.000000007
GFORM_FRAMEWORKS=entry.000000008
GFORM_CHANGES=entry.000000009
GFORM_FORMAT=entry.000000010
GFORM_TIMESTAMP=entry.000000011
