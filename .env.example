# ── App ───────────────────────────────────────────────────────────
# Public base URL. On Railway this is auto-set.
BASE_URL=https://your-app.up.railway.app

# ── Feedback storage ──────────────────────────────────────────────
# Path to the CSV file where trial submissions are logged.
# Defaults to /tmp/feedback.csv (resets on redeploy — use a mounted
# volume or replace _write_feedback() with a DB/Sheets write for persistence).
FEEDBACK_FILE=/tmp/feedback.csv

# ── Admin ─────────────────────────────────────────────────────────
# Protect GET /api/admin/feedback with a secret key.
# Leave blank to disable auth (not recommended in production).
ADMIN_KEY=change-me-to-a-secret
