# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PayPal ────────────────────────────────────────────────────────
# Get from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=AY...
PAYPAL_CLIENT_SECRET=EL...
# "sandbox" for testing, "live" for production
PAYPAL_ENV=sandbox

# ── Pricing ───────────────────────────────────────────────────────
# Cents. Default 2900 = $29.00
PRICE_CENTS=2900

# ── App ───────────────────────────────────────────────────────────
# Public base URL for payment redirects. On Railway this is auto-set.
BASE_URL=https://your-app.up.railway.app
