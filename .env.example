# ── App ────────────────────────────────────────────────────────────────────────
BASE_URL=https://your-app.up.railway.app

# ── Admin ──────────────────────────────────────────────────────────────────────
# Protects /admin and /admin/generate endpoints.
# Set a strong random string — e.g. openssl rand -hex 24
ADMIN_KEY="$6C2Gt5^^VT#JP2dq6YwppSq"

# ── Google Forms ───────────────────────────────────────────────────────────────
# Receives access request submissions. See README for setup.
# If not set, submissions are logged to Railway stdout only.
GFORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/formResponse
GFORM_NAME=entry.000000001
GFORM_EMAIL=entry.000000002
GFORM_COMPANY=entry.000000003
GFORM_ROLE=entry.000000004
GFORM_HOW_HEARD=entry.000000005
GFORM_USE_CASE=entry.000000006
GFORM_COLLECTION=entry.000000007
GFORM_FRAMEWORKS=entry.000000008
GFORM_CHANGES=entry.000000009
GFORM_FORMAT=entry.000000010
GFORM_TIMESTAMP=entry.000000011
